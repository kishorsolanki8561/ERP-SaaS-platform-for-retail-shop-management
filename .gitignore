# ── Secrets (NEVER commit) ────────────────────────────────────────────────────
.secrets.local
.env
.env.*
!.env.example
**/appsettings.Production.json
**/appsettings.Staging.json
# Prevent real connection strings from being committed to appsettings.json
# (use dotnet user-secrets for local overrides)

# ── .NET build output ─────────────────────────────────────────────────────────
**/bin/
**/obj/
**/out/
*.user
*.suo
.vs/
_ReSharper*/
*.DotSettings.user

# ── EF Core migrations temp ───────────────────────────────────────────────────
**/Migrations/*.Designer.cs

# ── NuGet ─────────────────────────────────────────────────────────────────────
.nuget/
packages/
*.nupkg
project.lock.json

# ── User secrets (stored outside repo by dotnet user-secrets — this is the ID) ─
# (actual secrets live in %APPDATA%/Microsoft/UserSecrets — not in repo)

# ── Test results + coverage ───────────────────────────────────────────────────
TestResults/
coverage/
**/coverage.cobertura.xml
*.trx
**/test-results/
**/playwright-report/

# ── Angular / Node ────────────────────────────────────────────────────────────
**/node_modules/
**/dist/
**/dist-server/
.angular/
*.js.map
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker override (local overrides are not committed) ───────────────────────
docker-compose.override.yml
