# Copy this file to .env and fill in values before running docker compose.
# NEVER commit .env — it is gitignored.

SQLSERVER_SA_PASSWORD=YourStrong@Passw0rd

# Initial platform-owner account seeded on first startup.
# For Azure App Service staging/prod, set these as Application Settings in the portal.
PRODUCT_OWNER_EMAIL=admin@shopearth.local
PRODUCT_OWNER_PASSWORD=Admin@123!
PRODUCT_OWNER_NAME=Platform Admin
