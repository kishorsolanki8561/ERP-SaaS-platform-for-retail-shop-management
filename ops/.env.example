# Copy this file to .env and fill in values before running docker compose.
# NEVER commit .env — it is gitignored.

# ── SQL Server ─────────────────────────────────────────────────────────────────
SQLSERVER_SA_PASSWORD=YourStrong@Passw0rd

# ── API ────────────────────────────────────────────────────────────────────────
# Port on the host where the API will be reachable (http://localhost:API_PORT)
API_PORT=5155

# ── Platform-owner seed account ───────────────────────────────────────────────
# Seeded by DatabaseSeeder on first startup; ignored on subsequent runs.
PRODUCT_OWNER_EMAIL=admin@shopearth.local
PRODUCT_OWNER_PASSWORD=Admin@123!
PRODUCT_OWNER_NAME=Platform Admin

# ── Demo data ─────────────────────────────────────────────────────────────────
# Set to true on first deploy to seed "Nexus Electronics" demo shop with
# products, customers, and invoices. Set back to false after first run.
Features__SeedDemoData=false
