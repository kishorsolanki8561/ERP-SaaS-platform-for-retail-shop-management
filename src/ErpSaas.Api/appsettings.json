{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PlatformDb": "Server=localhost,1433;Database=PlatformDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;",
    "TenantDb": "Server=localhost,1433;Database=TenantDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;",
    "AnalyticsDb": "Server=localhost,1433;Database=AnalyticsDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;",
    "LogDb": "Server=localhost,1433;Database=LogDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;",
    "NotificationsDb": "Server=localhost,1433;Database=NotificationsDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;",
    "MarketplaceEventsDb": "Server=localhost,1433;Database=MarketplaceEventsDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;",
    "SyncDb": "Server=localhost,1433;Database=SyncDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Hangfire": {
    "ConnectionStringName": "LogDb"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_USE_ENV_VAR_AT_LEAST_32_CHARS",
    "Issuer": "shopearth-erp",
    "Audience": "shopearth-erp-clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  }
}
